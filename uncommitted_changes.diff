+	_fx_residual = 0.f;
+
+	if (matrix_index == 0 && ENABLE_LINEAR_FX_YAW_ENERGY && _tilts.count() > 0) {
+		lazyInitTailTiltSubscription();
+
+		const auto &geom = _mc_rotors.geometry();
+
+		float f_fl = 0.f, f_fr = 0.f, f_tail = 0.f;
+		float y_fl_mean = 0.f, y_fr_mean = 0.f;
