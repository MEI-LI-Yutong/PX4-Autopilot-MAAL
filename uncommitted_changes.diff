+				} else {
+					theta_fl = theta_fr = 0.f;
+				}
+			}
+
+			// 限幅
+			auto limit = [&](float &a){ a = math::constrain(a, -MAX_LINEAR_TILT_RAD, MAX_LINEAR_TILT_RAD); };
+			limit(theta_fl); limit(theta_fr); limit(theta_tail);
