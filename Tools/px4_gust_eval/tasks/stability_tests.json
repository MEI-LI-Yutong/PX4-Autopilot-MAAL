{
  "test_suite": "Wind Stability Evaluation",
  "description": "Evaluate stability across baseline (no wind), sustained headwinds, and gusts using one_minus_cos model.",
  "px4_sitl_command": "make px4_sitl gz_tiltrotor_windy",
  "mission_type": "straight_line",
  "mission_config": {
    "takeoff_altitude": 10.0,
    "timeout_sec": 120,
    "advance_distance_m": 100.0,
    "advance_axis": "ned_y",
    "advance_after_hover_sec": 2
  },
  "wind_gust_tests": [
    {
      "test_id": "baseline_no_wind",
      "description": "Baseline: no wind (mean=0, gust_length=0)",
      "wind_config": {
        "model": "one_minus_cos",
        "mean": [0.0, 0.0, 0.0],
        "direction": [1.0, 0.0, 0.0],
        "gust_length": 0,
        "airspeed": 5.0,
        "phase": 0.0
      }
    },

    {
      "test_id": "steady_wind_x_neg5",
      "description": "Sustained wind: mean.x = -5 m/s (gust_length=0)",
      "wind_config": {
        "model": "one_minus_cos",
        "mean": [-5.0, 0.0, 0.0],
        "direction": [1.0, 0.0, 0.0],
        "gust_length": 0,
        "airspeed": 5.0,
        "phase": 0.0
      }
    },
