{
  "test_suite": "CSV Wind Replay (Key Metrics)",
  "description": "Replay CSV wind and record wind/position/attitude metrics",
  "px4_sitl_command": "make px4_sitl gz_x500_windy",
  "mission_type": "straight_line",
  "mission_config": {
    "takeoff_altitude": 20.0,
    "waypoints": [
      {"lat": 47.397742, "lon": 8.545594, "alt": 20.0},
      {"lat": 47.398242, "lon": 8.546094, "alt": 20.0}
    ],
    "airspeed": 12.0,
    "timeout_sec": 120
