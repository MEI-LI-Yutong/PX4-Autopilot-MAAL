{
  "test_suite": "Basic Validation Test Suite",
  "description": "Basic validation tests for wind gust framework functionality",
  "px4_sitl_command": "make px4_sitl gz_tiltrotor_windy",
  "mission_type": "straight_line",
  "mission_config": {
    "takeoff_altitude": 20.0,
    "waypoints": [
      {"lat": 47.397742, "lon": 8.545594, "alt": 20.0},
      {"lat": 47.398242, "lon": 8.546094, "alt": 20.0}
    ],
    "airspeed": 12.0,
    "timeout_sec": 90
  },
  "wind_gust_tests": [
    {
      "test_id": "no_wind_baseline",
      "description": "Baseline test with no wind",
      "wind_config": {
        "model": "sine",
        "mean": [0.0, 0.0, 0.0],
        "amplitude": [0.0, 0.0, 0.0],
        "frequency": 0.0,
        "phase": 0.0
      },
      "expected_results": {
        "max_position_error_m": 5.0,
        "max_altitude_deviation_m": 3.0,
        "mission_completion_expected": true
      }
    },
    {
      "test_id": "constant_light_wind",
      "description": "Constant light wind test",
      "wind_config": {
        "model": "sine",
        "mean": [3.0, 1.0, 0.0],
        "amplitude": [0.0, 0.0, 0.0],
        "frequency": 0.0,
        "phase": 0.0
      },
      "expected_results": {
        "max_position_error_m": 8.0,
        "max_altitude_deviation_m": 4.0,
        "mission_completion_expected": true
      }
    },
    {
      "test_id": "gentle_sine_wave",
      "description": "Gentle sinusoidal wind variation",
      "wind_config": {
        "model": "sine",
        "mean": [4.0, 0.0, 0.0],
        "amplitude": [1.5, 0.5, 0.2],
        "frequency": 0.05,
        "phase": 0.0
      },
      "expected_results": {
        "max_position_error_m": 10.0,
        "max_altitude_deviation_m": 5.0,
        "mission_completion_expected": true
      }
    }
  ],
  "output_config": {
    "log_directory": "logs/basic_validation",
    "generate_plots": false,
    "save_flight_data": true,
    "metrics_to_track": [
      "position_error",
      "altitude_deviation",
      "mission_completion_time"
    ]
  }
}