{
  "test_suite": "Wind Gust Evaluation Suite",
  "description": "Test suite for evaluating tiltrotor performance under various wind gust conditions",
  "px4_sitl_command": "make px4_sitl gz_tiltrotor_windy",
  "mission_type": "straight_line",
  "mission_config": {
    "takeoff_altitude": 5.0,
    "waypoints": [
      {"lat": 47.397742, "lon": 8.545594, "alt": 5.0},
      {"lat": 47.398742, "lon": 8.546594, "alt": 5.0},
      {"lat": 47.399742, "lon": 8.549594, "alt": 5.0}
    ],
    "airspeed": 10.0,
    "timeout_sec": 100
  },
  "wind_gust_tests": [
    {
      "test_id": "gust_one_minus_cos_long",
      "description": "Long duration 1-cos gust model",
      "wind_config": {
        "model": "one_minus_cos",
        "mean": [-10.0, 0.0, -10.0],
        "gust_length": 100.0,
        "airspeed": 10.0,
        "direction": [1.0, 0.0, 0.0],
        "phase": 0.0
      },
      "expected_results": {
        "max_position_error_m": 20.0,
        "max_altitude_deviation_m": 10.0,
        "mission_completion_expected": true
      }
    },
    {
      "test_id": "gust_one_minus_cos_long",
      "description": "Long duration 1-cos gust model",
      "wind_config": {
        "model": "one_minus_cos",
        "mean": [0.0, 0.0, 0.0],
        "gust_length": 0.0,
        "airspeed": 10.0,
        "direction": [1.0, 0.0, 0.0],
        "phase": 0.0
      },
      "expected_results": {
        "max_position_error_m": 20.0,
        "max_altitude_deviation_m": 10.0,
        "mission_completion_expected": true
      }
    }
  ],
  "output_config": {
    "log_directory": "logs",
    "generate_plots": true,
    "save_flight_data": true,
    "metrics_to_track": [
      "position_error",
      "altitude_deviation",
      "airspeed_variation",
      "attitude_deviation",
      "mission_completion_time"
    ]
  }
}
