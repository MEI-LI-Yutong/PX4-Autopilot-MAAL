{
  "test_suite": "Severe Weather Conditions Test Suite",
  "description": "Test suite for evaluating tiltrotor performance under severe wind gust conditions",
  "px4_sitl_command": "make px4_sitl gz_tiltrotor_windy",
  "mission_type": "straight_line",
  "mission_config": {
    "takeoff_altitude": 75.0,
    "waypoints": [
      {"lat": 47.397742, "lon": 8.545594, "alt": 75.0},
      {"lat": 47.399242, "lon": 8.547594, "alt": 75.0},
      {"lat": 47.400742, "lon": 8.549594, "alt": 75.0},
      {"lat": 47.402242, "lon": 8.551594, "alt": 75.0}
    ],
    "airspeed": 20.0,
    "timeout_sec": 400
  },
  "wind_gust_tests": [
    {
      "test_id": "severe_headwind_gust",
      "description": "Severe headwind with strong gusts",
      "wind_config": {
        "model": "sine",
        "mean": [15.0, 0.0, 0.0],
        "amplitude": [10.0, 3.0, 2.0],
        "frequency": 0.3,
        "phase": 0.0
      },
      "expected_results": {
        "max_position_error_m": 30.0,
        "max_altitude_deviation_m": 15.0,
        "mission_completion_expected": true
      }
    },
    {
      "test_id": "severe_crosswind_variable",
      "description": "Severe variable crosswind",
      "wind_config": {
        "model": "sine",
        "mean": [5.0, 12.0, 0.0],
        "amplitude": [3.0, 8.0, 3.0],
        "frequency": 0.25,
        "phase": 1.57
      },
      "expected_results": {
        "max_position_error_m": 40.0,
        "max_altitude_deviation_m": 12.0,
        "mission_completion_expected": true
      }
    },
    {
      "test_id": "extreme_vertical_gust",
      "description": "Extreme vertical wind gusts",
      "wind_config": {
        "model": "sine",
        "mean": [8.0, 2.0, 0.0],
        "amplitude": [2.0, 1.0, 6.0],
        "frequency": 0.4,
        "phase": 0.0
      },
      "expected_results": {
        "max_position_error_m": 25.0,
        "max_altitude_deviation_m": 20.0,
        "mission_completion_expected": true
      }
    },
    {
      "test_id": "turbulent_one_minus_cos",
      "description": "Turbulent 1-cos gust with rapid changes",
      "wind_config": {
        "model": "one_minus_cos",
        "mean": [10.0, 5.0, 0.0],
        "gust_length": 30.0,
        "airspeed": 20.0,
        "direction": [0.8, 0.6, 0.2],
        "phase": 4.71
      },
      "expected_results": {
        "max_position_error_m": 35.0,
        "max_altitude_deviation_m": 18.0,
        "mission_completion_expected": false
      }
    }
  ],
  "output_config": {
    "log_directory": "logs/severe_weather",
    "generate_plots": true,
    "save_flight_data": true,
    "metrics_to_track": [
      "position_error",
      "altitude_deviation",
      "airspeed_variation",
      "attitude_deviation",
      "mission_completion_time",
      "control_surface_deflection",
      "motor_saturation"
    ]
  }
}