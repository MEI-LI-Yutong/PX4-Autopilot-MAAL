{
  "test_suite": "Wind Levels (Sustained & Gust)",
  "description": "26 gust-only tasks: 13 along -X and 13 along -Z. Uses one_minus_cos_simp with T=10s and A0 set to the target |V| level.",
  "px4_sitl_command": "make px4_sitl gz_x500_windy",
  "mission_type": "straight_line",
  "wandb": {
      "enable": true,
      "entity": "MAALab",
      "upload_config": true
    },
  "mission_config": {
    "takeoff_altitude": 10.0,
    "timeout_sec": 150,
    "advance_distance_m": 100.0,
    "advance_axis": "ned_y",
    "advance_after_hover_sec": 2
  },
  "sdf_edit": {
	"path": "../../simulation/gz/models/x500_base/model.sdf",
	"patches": [
	  {
	    "select": { "link": "base_link", "path": "inertial/mass" },
	    "value": 2.0
	  },
	  {
	    "select": { "link": "base_link", "path": "inertial/inertia/izz" },
	    "value": 0.01
	  }
	]
      },
  "wind_gust_tests": [
		{"test_id": "gust_lvl_y_06", "description": "Gust Y-L6: |V|=4.40 m/s (mean=0, Y-dir)", "wind_config": {"model": "one_minus_cos_simp", "mean": [0,0,0], "direction": [-0.939,0.342,0], "A0": 4.40, "T": 10, "phase": 0.0, "trigger_x": 30.0, "trigger_model": "x500_0" }}
  ],
  "output_config": {
    "log_directory": "logs/levels",
    "save_flight_data": true
  }
}
